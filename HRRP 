def demonstrate_hrrp_classification():
    """
    Demonstrate HRRP for aircraft classification
    """
    
    # Initialize simulator
    simulator = HRRPSimulator(fc=10e9, B=1e9)
    
    # Define aircraft to classify
    aircraft_list = [
        'F-16 Fighting Falcon',
        'Su-35 Flanker',
        'F-22 Raptor',
        'MiG-29 Fulcrum',
        'MQ-9 Reaper (UAV)'
    ]
    
    # Generate HRRP for each aircraft at multiple aspects
    aspects = [0, 30, 60]  # nose-on, 30°, 60°
    
    # Create figure
    fig = plt.figure(figsize=(20, 15))
    
    # Store features for classification
    all_features = []
    
    for i, aircraft in enumerate(aircraft_list):
        print(f"\n{'='*60}")
        print(f"Processing: {aircraft}")
        print('='*60)
        
        # Get aircraft model
        model = simulator.create_aircraft_model(aircraft)
        
        # Create subplot grid for this aircraft
        for j, aspect in enumerate(aspects):
            # Generate HRRP
            range_axis, hrrp, positions, rcs = simulator.generate_hrrp(
                model, aspect_angle=aspect, snr_db=25, fluctuation='swerling1'
            )
            
            # Extract features
            features = simulator.extract_features(hrrp, range_axis)
            all_features.append({
                'aircraft': aircraft,
                'aspect': aspect,
                'features': features
            })
            
            # Plot HRRP
            ax = plt.subplot(len(aircraft_list), len(aspects), 
                           i*len(aspects) + j + 1)
            
            # Plot HRRP
            ax.plot(range_axis, hrrp, 'b-', linewidth=1.5, alpha=0.7)
            
            # Mark true scatterer positions
            for pos, rcs_val in zip(positions, rcs):
                ax.axvline(x=pos, color='r', linestyle='--', 
                          alpha=0.5, linewidth=1)
                ax.plot(pos, rcs_val * 0.1, 'ro', markersize=3)
            
            # Formatting
            ax.set_xlim([-15, 25])
            ax.set_ylim([0, None])
            ax.grid(True, alpha=0.3)
            
            if j == 0:
                ax.set_ylabel(f'{aircraft}\nMagnitude', fontsize=9)
            if i == len(aircraft_list) - 1:
                ax.set_xlabel('Range (m)', fontsize=9)
            
            ax.set_title(f'Aspect: {aspect}°', fontsize=10)
            
            # Annotate with key features
            feature_text = (f"Peaks: {features['num_peaks']}\n"
                          f"Length: {features['length_estimate']:.1f}m")
            ax.text(0.95, 0.95, feature_text, 
                   transform=ax.transAxes,
                   verticalalignment='top',
                   horizontalalignment='right',
                   bbox=dict(boxstyle='round', facecolor='wheat', alpha=0.5),
                   fontsize=8)
    
    plt.suptitle('HRRP Signatures for Different Aircraft at Multiple Aspects\n'
                'Red dashed lines: True scatterer positions', 
                fontsize=14, fontweight='bold')
    plt.tight_layout()
    plt.show()
    
    return all_features

def demonstrate_classification_metrics(all_features):
    """
    Show how features can be used for classification
    """
    
    print("\n" + "="*70)
    print("CLASSIFICATION FEATURES ANALYSIS")
    print("="*70)
    
    # Group features by aircraft
    aircraft_features = {}
    for data in all_features:
        aircraft = data['aircraft']
        if aircraft not in aircraft_features:
            aircraft_features[aircraft] = []
        aircraft_features[aircraft].append(data['features'])
    
    # Create feature comparison plot
    fig, axes = plt.subplots(2, 3, figsize=(15, 10))
    
    feature_names = ['length_estimate', 'num_peaks', 'centroid', 
                    'spread', 'skewness', 'kurtosis']
    titles = ['Length (m)', 'Number of Peaks', 'Centroid Position (m)',
             'Energy Spread (m)', 'Skewness', 'Kurtosis']
    
    colors = plt.cm.Set3(np.linspace(0, 1, len(aircraft_features)))
    
    for idx, (feature_name, title) in enumerate(zip(feature_names, titles)):
        ax = axes.flatten()[idx]
        
        x_pos = np.arange(len(aircraft_features))
        means = []
        stds = []
        labels = []
        
        for i, (aircraft, features_list) in enumerate(aircraft_features.items()):
            values = [f[feature_name] for f in features_list]
            means.append(np.mean(values))
            stds.append(np.std(values))
            labels.append(aircraft.split()[0])  # Short name
            
        ax.bar(x_pos, means, yerr=stds, capsize=5, color=colors)
        ax.set_xticks(x_pos)
        ax.set_xticklabels(labels, rotation=45, ha='right')
        ax.set_ylabel(title)
        ax.grid(True, alpha=0.3)
        ax.set_title(f'Feature: {title}')
    
    plt.suptitle('Feature Distribution Across Aircraft Types\n'
                '(Bars show mean ± std over multiple aspects)', 
                fontsize=14, fontweight='bold')
    plt.tight_layout()
    plt.show()
    
    # Print feature summary
    print("\nFEATURE SUMMARY (mean ± std):")
    print("-"*70)
    for aircraft, features_list in aircraft_features.items():
        print(f"\n{aircraft}:")
        for feature_name in feature_names[:3]:  # First 3 features
            values = [f[feature_name] for f in features_list]
            print(f"  {feature_name:20s}: {np.mean(values):6.2f} ± {np.std(values):5.2f}")

def demonstrate_aspect_sensitivity():
    """
    Show how HRRP changes with aspect angle
    """
    
    simulator = HRRPSimulator(fc=10e9, B=1e9)
    
    # Choose one aircraft
    aircraft = 'F-16 Fighting Falcon'
    model = simulator.create_aircraft_model(aircraft)
    
    # Generate HRRP at multiple aspects
    aspects = np.arange(0, 91, 15)  # 0° to 90° in 15° steps
    
    fig, axes = plt.subplots(2, 3, figsize=(15, 10))
    axes = axes.flatten()
    
    for idx, aspect in enumerate(aspects):
        range_axis, hrrp, positions, rcs = simulator.generate_hrrp(
            model, aspect_angle=aspect, snr_db=30
        )
        
        ax = axes[idx]
        
        # Plot HRRP
        ax.plot(range_axis, hrrp, 'b-', linewidth=1.5)
        
        # Mark true scatterer positions
        for pos in positions:
            ax.axvline(x=pos, color='r', linestyle='--', alpha=0.5)
        
        ax.set_xlim([-10, 20])
        ax.set_ylim([0, None])
        ax.grid(True, alpha=0.3)
        ax.set_xlabel('Range (m)')
        ax.set_ylabel('Magnitude')
        ax.set_title(f'Aspect: {aspect}°')
        
        # Annotate projected length
        proj_length = np.max(positions) - np.min(positions)
        ax.text(0.95, 0.95, f'Proj Length: {proj_length:.1f}m',
               transform=ax.transAxes, ha='right', va='top',
               bbox=dict(boxstyle='round', facecolor='wheat', alpha=0.5))
    
    plt.suptitle(f'Aspect Sensitivity of HRRP - {aircraft}', 
                fontsize=14, fontweight='bold')
    plt.tight_layout()
    plt.show()

