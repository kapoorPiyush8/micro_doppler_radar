    def generate_hrrp(self, aircraft_model, aspect_angle=0, snr_db=30, 
                     num_freq=256, fluctuation='swerling1'):
        """
        Generate HRRP for given aircraft at specified aspect angle
        
        Parameters:
        -----------
        aircraft_model : dict
            Aircraft model with scatterers
        aspect_angle : float
            Aspect angle in degrees (0 = nose-on, 90 = broadside)
        snr_db : float
            Signal-to-noise ratio in dB
        num_freq : int
            Number of frequency steps
        fluctuation : str
            RCS fluctuation model ('swerling1', 'swerling2', 'none')
        """
        
        # Extract scatterer positions and RCS
        scatterers = aircraft_model['scatterers']
        length = aircraft_model['length']
        
        # Apply aspect angle effect
        # At non-zero aspect, the projected length changes
        aspect_rad = np.radians(aspect_angle)
        proj_factor = np.cos(aspect_rad)
        
        # Adjust positions based on aspect
        positions = np.array([s['pos'] for s in scatterers])
        # Normalize to [0, 1] range for projection
        positions_norm = positions / length
        # Apply projection (compression along LOS)
        positions_proj = positions_norm * proj_factor * length
        
        # Get base RCS values
        rcs_values = np.array([s['rcs'] for s in scatterers])
        
        # Apply RCS fluctuation (Swerling models)
        if fluctuation == 'swerling1':
            # Slow fluctuation (scan-to-scan)
            rcs_values *= np.random.exponential(1, len(rcs_values))
        elif fluctuation == 'swerling2':
            # Fast fluctuation (pulse-to-pulse)
            rcs_values *= np.random.rayleigh(1, len(rcs_values))
        
        # Generate frequency domain response
        freq = np.linspace(self.fc - self.B/2, self.fc + self.B/2, num_freq)
        k = 2 * np.pi * freq / self.c  # Wavenumber
        
        # Construct frequency response (sum of scatterers)
        H_f = np.zeros(len(freq), dtype=complex)
        
        for pos, rcs in zip(positions_proj, rcs_values):
            # Phase delay due to round trip
            phase = -2j * k * pos
            H_f += np.sqrt(rcs) * np.exp(phase)
        
        # Add aspect-dependent shading (scatterers may be occluded)
        if aspect_angle > 60:
            # At high aspects, some scatterers are shadowed
            occlusion = np.exp(-(positions_proj - length/2)**2 / (length/4)**2)
            H_f *= np.sum(occlusion) / len(occlusion)
        
        # Convert to time domain (HRRP) via IFFT
        hrrp = np.fft.ifft(H_f, n=4*num_freq)
        hrrp = np.fft.fftshift(hrrp)  # Center the profile
        
        # Create range axis
        range_max = self.c / (2 * self.delta_r)
        range_axis = np.linspace(-range_max/2, range_max/2, len(hrrp))
        
        # Add noise
        signal_power = np.mean(np.abs(hrrp)**2)
        noise_power = signal_power / (10**(snr_db/10))
        noise = np.sqrt(noise_power/2) * (np.random.randn(len(hrrp)) + 
                                          1j*np.random.randn(len(hrrp)))
        hrrp_noisy = hrrp + noise
        
        return range_axis, np.abs(hrrp_noisy), positions_proj, rcs_values
    
    def extract_features(self, hrrp_profile, range_axis):
        """
        Extract classification features from HRRP
        """
        features = {}
        
        # Normalize profile
        profile_norm = hrrp_profile / np.max(hrrp_profile)
        
        # 1. Length estimate (where profile > threshold)
        threshold = 0.2  # 20% of peak
        above_thresh = np.where(profile_norm > threshold)[0]
        if len(above_thresh) > 0:
            length_estimate = range_axis[above_thresh[-1]] - range_axis[above_thresh[0]]
            features['length_estimate'] = length_estimate
        else:
            features['length_estimate'] = 0
        
        # 2. Number of prominent peaks
        from scipy.signal import find_peaks
        peaks, properties = find_peaks(profile_norm, height=0.3, distance=5)
        features['num_peaks'] = len(peaks)
        features['peak_positions'] = range_axis[peaks]
        features['peak_heights'] = properties['peak_heights']
        
        # 3. Energy distribution (centroid and spread)
        energy = profile_norm**2
        if np.sum(energy) > 0:
            centroid = np.sum(range_axis * energy) / np.sum(energy)
            spread = np.sqrt(np.sum((range_axis - centroid)**2 * energy) / np.sum(energy))
        else:
            centroid = 0
            spread = 0
        features['centroid'] = centroid
        features['spread'] = spread
        
        # 4. Profile moments (skewness, kurtosis)
        from scipy.stats import skew, kurtosis
        features['skewness'] = skew(profile_norm)
        features['kurtosis'] = kurtosis(profile_norm)
        
        return features

