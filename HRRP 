class HRRPSimulator:
    """
    High Range Resolution Profile Simulator for Aircraft Classification
    Simulates RCS distribution along the aircraft's length (phase center)
    """
    
    def __init__(self, fc=10e9, B=1e9, fc_ratio=0.1):
        """
        Initialize HRRP Simulator
        
        Parameters:
        -----------
        fc : float
            Carrier frequency (Hz) - default 10 GHz
        B : float
            Bandwidth (Hz) - default 1 GHz gives 0.15m range resolution
        fc_ratio : float
            Fluctuation correlation ratio (0.1 = 10% correlation)
        """
        self.c = 3e8  # Speed of light
        self.fc = fc
        self.B = B
        self.fc_ratio = fc_ratio
        
        # Calculate range resolution
        self.delta_r = self.c / (2 * B)
        print(f"Range Resolution: {self.delta_r:.3f} m")
        
